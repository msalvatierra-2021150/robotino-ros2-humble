<?xml version="1.0"?>
<robot xmlns:xacro="http://www.ros.org/wiki/xacro" name="logitech_c920_camera">
  <xacro:property name="M_PI" value="3.14159"/>
  <xacro:macro name="camera" params="name parent *origin">

    <!-- Stem: vertical mount/clip -->
    <joint name="${name}_mount_joint" type="fixed">
      <parent link="${parent}"/>
      <child  link="${name}_mount_link"/>
      <xacro:insert_block name="origin"/>
    </joint>

    <link name="${name}_mount_link">
      <visual>
        <origin xyz="0 0.03 0" rpy="0 0 ${M_PI/2}"/>
        <geometry>
          <box size="0.04 0.02 0.01"/>
        </geometry>
        <material name="camera_dark_grey">
          <color rgba="0.0 0.0 0.0 1.0"/>
        </material>
      </visual>
      <collision>
        <origin xyz="0 0.03 0" rpy="0 0 ${M_PI/2}"/>
          <box size="0.04 0.02 0.01"/>
      </collision>
      <inertial>
        <mass value="0.02"/>
        <inertia ixx="1e-6" ixy="0" ixz="0"
                 iyy="1e-6" iyz="0" izz="1e-6"/>
      </inertial>
    </link>

    <!-- Bar: horizontal lens body (top of the T) -->
    <joint name="${name}_bar_joint" type="fixed">
      <parent link="${name}_mount_link"/>
      <child  link="${name}_bar_link"/>
      <origin xyz="0 0 0.02" rpy="0 0 0"/>
    </joint>

    <link name="${name}_bar_link">
      <visual>
        <origin xyz="0 0 0" rpy="0 0 0"/>
        <geometry>
          <box size="0.08 0.03 0.03"/>
        </geometry>
        <material name="camera_black">
          <color rgba="0.0 0.0 0.0 1.0"/>
        </material>
      </visual>

      <collision>
        <origin xyz="0 0 0" rpy="0 0 0"/>
        <geometry>
          <box size="0.08 0.03 0.03"/>
        </geometry>
      </collision>

      <inertial>
        <mass value="0.16"/>
        <inertia ixx="1e-4" ixy="0" ixz="0"
                iyy="1e-5" iyz="0" izz="1e-4"/>
      </inertial>
    </link>

    <!-- Optical frame -->
    <joint name="${name}_optical_joint" type="fixed">
      <parent link="${name}_bar_link"/>
      <child  link="${name}_optical_frame"/>
      <origin xyz="0 0 0.02" rpy="-1.5708 0 -1.5708"/>
    </joint>

    <link name="${name}_optical_frame"/>

    <gazebo reference="${name}_bar_link">
      <!-- add sensor plugin here if needed -->
    </gazebo>

  </xacro:macro>

</robot>